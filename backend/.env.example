# Backend environment variables
# Copy this file to .env and fill in your values

# PostgreSQL connection string (Neon, Supabase, local, etc.)
# Example:
# DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# JWT secret — use a long random string in production
JWT_SECRET="your-secret-key-here"

# Server
PORT=8080
NODE_ENV=development

# JWT expiry
JWT_EXPIRES_IN=7d

# Development-only bootstrap login shown in the frontend login form.
# The backend will upsert this user automatically when NODE_ENV=development.
DEV_AUTH_EMAIL="test@lumex.com"
DEV_AUTH_PASSWORD="password"
DEV_AUTH_NAME="Lumex Test User"
DEV_AUTH_ROLE="ADMIN"
